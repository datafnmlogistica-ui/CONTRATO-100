<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CONTRATO 100</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            overflow: hidden;
            background-color: #121212; /* Fondo oscuro idéntico al neón */
        }
        
        /* Contenedor que bloquea el desbordamiento y oculta la barra de Google */
        .contenedor-seguro {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        /* Oculta la barra de aviso de abuso levantando el iframe exactamente 48px */
        iframe {
            position: absolute;
            top: -48px; 
            left: 0;
            width: 100%;
            height: calc(100% + 48px); 
            border: none;
        }
    </style>
</head>
<body>

    <div class="contenedor-seguro">
        <iframe src="https://script.google.com/macros/s/AKfycbzsaqP7LHyTQSHaig5ICvf8RZHE5sFnq7-E9SwP7leaYbizElgiZtW69Q5vEEeZ1Z0/exec"></iframe>
    </div>

</body>
</html>
